<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#0a0a0a"
    android:padding="24dp">

    <TextView
        android:id="@+id/speedValue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="--"
        android:textColor="#ffffff"
        android:textSize="72sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="км/год"
        android:textColor="#666666"
        android:textSize="16sp"
        android:layout_marginBottom="32dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Speed Limit"
        android:textColor="#ffc107"
        android:textSize="18sp"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/limitValue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="90 км/год"
        android:textColor="#ffffff"
        android:textSize="36sp"
        android:textStyle="bold"
        android:layout_marginBottom="32dp" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <Button
            android:id="@+id/btn_88"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:text="88"
            android:textSize="16sp"
            android:textStyle="bold"
            android:background="@drawable/limit_btn_bg"
            android:textColor="#ffffff"
            android:layout_margin="4dp" />

        <Button
            android:id="@+id/btn_89"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:text="89"
            android:textSize="16sp"
            android:textStyle="bold"
            android:background="@drawable/limit_btn_bg"
            android:textColor="#ffffff"
            android:layout_margin="4dp" />

        <Button
            android:id="@+id/btn_90"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:text="90"
            android:textSize="16sp"
            android:textStyle="bold"
            android:background="@drawable/limit_btn_bg"
            android:textColor="#ffffff"
            android:layout_margin="4dp" />

        <Button
            android:id="@+id/btn_91"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:text="91"
            android:textSize="16sp"
            android:textStyle="bold"
            android:background="@drawable/limit_btn_bg"
            android:textColor="#ffffff"
            android:layout_margin="4dp" />

        <Button
            android:id="@+id/btn_92"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:text="92"
            android:textSize="16sp"
            android:textStyle="bold"
            android:background="@drawable/limit_btn_bg"
            android:textColor="#ffffff"
            android:layout_margin="4dp" />
    </LinearLayout>

</LinearLayout>